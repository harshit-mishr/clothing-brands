{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- if section.settings.enable_quick_add -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- liquid
  assign featured_tag = section.settings.featured_product_tag | strip
  if featured_tag == blank
    assign featured_tag = 'featured'
  endif
  assign initial_featured_max = 15
  assign initial_normal_count = 5
  assign initial_total = initial_featured_max | plus: initial_normal_count
  assign infinite_batch = section.settings.infinite_scroll_batch

  # List filters use active_values; price_range uses min_value/max_value (see snippets/facets.liquid).
  assign filters_active = false
  for cf in collection.filters
    if cf.active_values.size > 0
      assign filters_active = true
    endif
    if cf.type == 'price_range'
      if cf.min_value.value != null or cf.max_value.value != null
        assign filters_active = true
      endif
    endif
  endfor

  assign sort_is_non_default = false
  if collection.sort_by != blank and collection.sort_by != collection.default_sort_by
    assign sort_is_non_default = true
  endif

  assign use_custom_featured_grid = false
  if section.settings.enable_featured_priority and collection.products.size > 0
    unless filters_active or sort_is_non_default
      assign use_custom_featured_grid = true
    endunless
  endif

  assign filtered_scroll_enabled = true
  if section.settings.enable_infinite_scroll_filtered_sorted == false
    assign filtered_scroll_enabled = false
  endif

  assign use_filtered_infinite_scroll = false
  if filtered_scroll_enabled and collection.products.size > 0
    unless use_custom_featured_grid
      if filters_active or sort_is_non_default
        assign use_filtered_infinite_scroll = true
      endif
    endunless
  endif

  assign paginate_size = section.settings.products_per_page
  if use_custom_featured_grid
    assign paginate_size = 50
  elsif use_filtered_infinite_scroll
    assign paginate_size = infinite_batch
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .collection-infinite-scroll-status {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 4rem;
    padding: 1rem 0 2rem;
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}">
  {%- paginate collection.products by paginate_size -%}
    {% comment %} Sort is the first tabbable element when filter type is vertical {% endcomment %}
    {%- if section.settings.enable_sorting and section.settings.filter_type == 'vertical' -%}
      <facet-filters-form class="facets facets-vertical-sort page-width small-hide no-js-hidden">
        <form class="facets-vertical-form" id="FacetSortForm">
          <div class="facet-filters sorting caption">
            <div class="facet-filters__field">
              <h2 class="facet-filters__label caption-large text-body">
                <label for="SortBy">{{ 'products.facets.sort_by_label' | t }}</label>
              </h2>
              <div class="select">
                {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
                <select
                  name="sort_by"
                  class="facet-filters__sort select__select caption-large"
                  id="SortBy"
                  aria-describedby="a11y-refresh-page-message"
                >
                  {%- for option in collection.sort_options -%}
                    <option
                      value="{{ option.value | escape }}"
                      {% if option.value == sort_by %}
                        selected="selected"
                      {% endif %}
                    >
                      {{ option.name | escape }}
                    </option>
                  {%- endfor -%}
                </select>
                {% render 'icon-caret' %}
              </div>
            </div>
            <noscript>
              <button type="submit" class="facets__button-no-js button button--secondary">
                {{ 'products.facets.sort_button' | t }}
              </button>
            </noscript>
          </div>

          <div class="product-count-vertical light" role="status">
            <h2 class="product-count__text text-body">
              <span id="ProductCountDesktop">
                {%- if collection.results_count -%}
                  {{
                    'templates.search.results_with_count'
                    | t: terms: collection.terms, count: collection.results_count
                  }}
                {%- elsif collection.products_count == collection.all_products_count -%}
                  {{ 'products.facets.product_count_simple' | t: count: collection.products_count }}
                {%- else -%}
                  {{
                    'products.facets.product_count'
                    | t: product_count: collection.products_count, count: collection.all_products_count
                  }}
                {%- endif -%}
              </span>
            </h2>
            {%- render 'loading-spinner' -%}
          </div>
        </form>
      </facet-filters-form>
    {%- endif -%}

    <div class="{% if section.settings.filter_type == 'vertical' %} facets-vertical page-width{% endif %}">
      {{ 'component-facets.css' | asset_url | stylesheet_tag }}
      <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
      {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
        <aside
          aria-labelledby="verticalTitle"
          class="facets-wrapper{% unless section.settings.enable_filtering %} facets-wrapper--no-filters{% endunless %}{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
          id="main-collection-filters"
          data-id="{{ section.id }}"
        >
          {% render 'facets',
            results: collection,
            enable_filtering: section.settings.enable_filtering,
            enable_sorting: section.settings.enable_sorting,
            filter_type: section.settings.filter_type,
            paginate: paginate
          %}
        </aside>
      {%- endif -%}

      <div
        class="product-grid-container{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        id="ProductGridContainer"
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
        {% endif %}
      >
        {%- if collection.products.size == 0 -%}
          <div class="collection collection--empty page-width" id="product-grid" data-id="{{ section.id }}">
            <div class="loading-overlay gradient"></div>
            <div class="title-wrapper center">
              <h2 class="title title--primary">
                {{ 'sections.collection_template.empty' | t -}}
                <br>
                {{
                  'sections.collection_template.use_fewer_filters_html'
                  | t: link: collection.url, class: 'underlined-link link'
                }}
              </h2>
            </div>
          </div>
        {%- else -%}
          <div class="collection{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}">
            <div class="loading-overlay gradient"></div>

            {%- if use_custom_featured_grid -%}
              {%- comment -%}
                Split handles from the first Liquid page (max 50). JavaScript reconciles with products.json
                so featured items beyond this window still appear in the correct first screen.
              {%- endcomment -%}
              {%- capture joined_featured -%}
                {%- for product in collection.products -%}
                  {%- if product.tags contains featured_tag -%}
                    {{- product.handle }}||{%- endif -%}
                {%- endfor -%}
              {%- endcapture -%}
              {%- capture joined_normal -%}
                {%- for product in collection.products -%}
                  {%- unless product.tags contains featured_tag -%}
                    {{- product.handle }}||{%- endunless -%}
                {%- endfor -%}
              {%- endcapture -%}
              {%- assign featured_handle_list = joined_featured | split: '||' -%}
              {%- assign normal_handle_list = joined_normal | split: '||' -%}

              <script type="application/json" id="CollectionInfiniteScrollConfig">
                {
                  "collectionHandle": {{ collection.handle | json }},
                  "featuredTag": {{ featured_tag | json }},
                  "initialFeaturedMax": {{ initial_featured_max }},
                  "initialNormalCount": {{ initial_normal_count }},
                  "batchSize": {{ infinite_batch }},
                  "view": "ajax-card",
                  "sectionId": "ajax-product-card"
                }
              </script>

              <ul
                id="product-grid"
                data-id="{{ section.id }}"
                data-use-custom-infinite="true"
                class="
                  grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down
                  grid--{{ section.settings.columns_desktop }}-col-desktop
                "
              >
                {%- liquid
                  assign display_index = 0
                  assign shown_featured = 0
                -%}
                {%- for handle_token in featured_handle_list -%}
                  {%- assign hclean = handle_token | strip -%}
                  {%- if hclean == blank or shown_featured >= initial_featured_max -%}
                    {%- continue -%}
                  {%- endif -%}
                  {%- assign card_product = all_products[hclean] -%}
                  {%- if card_product == blank -%}
                    {%- continue -%}
                  {%- endif -%}
                  {%- assign display_index = display_index | plus: 1 -%}
                  {%- assign lazy_load = false -%}
                  {%- if display_index > 2 -%}
                    {%- assign lazy_load = true -%}
                  {%- endif -%}
                  <li
                    class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                    data-product-id="{{ card_product.id }}"
                    data-product-handle="{{ card_product.handle | escape }}"
                    {% if settings.animations_reveal_on_scroll %}
                      data-cascade
                      style="--animation-order: {{ display_index }};"
                    {% endif %}
                  >
                    {% render 'card-product',
                      card_product: card_product,
                      media_aspect_ratio: section.settings.image_ratio,
                      image_shape: section.settings.image_shape,
                      show_secondary_image: section.settings.show_secondary_image,
                      show_vendor: section.settings.show_vendor,
                      show_rating: section.settings.show_rating,
                      lazy_load: lazy_load,
                      show_quick_add: section.settings.enable_quick_add,
                      section_id: section.id
                    %}
                  </li>
                  {%- assign shown_featured = shown_featured | plus: 1 -%}
                {%- endfor -%}

                {%- liquid
                  assign slots_for_normal = initial_total | minus: shown_featured
                  if slots_for_normal < 0
                    assign slots_for_normal = 0
                  endif
                  assign shown_normal = 0
                -%}
                {%- for handle_token in normal_handle_list -%}
                  {%- assign hclean = handle_token | strip -%}
                  {%- if hclean == blank or shown_normal >= slots_for_normal -%}
                    {%- continue -%}
                  {%- endif -%}
                  {%- assign card_product = all_products[hclean] -%}
                  {%- if card_product == blank -%}
                    {%- continue -%}
                  {%- endif -%}
                  {%- assign display_index = display_index | plus: 1 -%}
                  {%- assign lazy_load = false -%}
                  {%- if display_index > 2 -%}
                    {%- assign lazy_load = true -%}
                  {%- endif -%}
                  <li
                    class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                    data-product-id="{{ card_product.id }}"
                    data-product-handle="{{ card_product.handle | escape }}"
                    {% if settings.animations_reveal_on_scroll %}
                      data-cascade
                      style="--animation-order: {{ display_index }};"
                    {% endif %}
                  >
                    {% render 'card-product',
                      card_product: card_product,
                      media_aspect_ratio: section.settings.image_ratio,
                      image_shape: section.settings.image_shape,
                      show_secondary_image: section.settings.show_secondary_image,
                      show_vendor: section.settings.show_vendor,
                      show_rating: section.settings.show_rating,
                      lazy_load: lazy_load,
                      show_quick_add: section.settings.enable_quick_add,
                      section_id: section.id
                    %}
                  </li>
                  {%- assign shown_normal = shown_normal | plus: 1 -%}
                {%- endfor -%}
              </ul>

              <div
                class="collection-infinite-scroll-status"
                id="CollectionInfiniteScrollStatus"
                aria-live="polite"
                aria-busy="false"
              >
                {% render 'loading-spinner', class: 'loading__spinner hidden' %}
              </div>
              <div id="CollectionInfiniteScrollSentinel" hidden aria-hidden="true"></div>

            {%- else -%}
              {%- if use_filtered_infinite_scroll -%}
                <script type="application/json" id="CollectionInfiniteScrollConfig">
                  {
                    "mode": "facet-section",
                    "sectionId": {{ section.id | json }},
                    "perPage": {{ paginate_size }},
                    "initialPage": {{ paginate.current_page }},
                    "totalPages": {{ paginate.pages }}
                  }
                </script>
              {%- endif -%}

              <ul
                id="product-grid"
                data-id="{{ section.id }}"
                {% if use_filtered_infinite_scroll %}
                  data-use-facet-infinite="true"
                {% endif %}
                class="
                  grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down
                  grid--{{ section.settings.columns_desktop }}-col-desktop
                "
              >
                {%- for product in collection.products -%}
                  {% assign lazy_load = false %}
                  {%- if forloop.index > 2 -%}
                    {%- assign lazy_load = true -%}
                  {%- endif -%}
                  <li
                    class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                    data-product-id="{{ product.id }}"
                    data-product-handle="{{ product.handle | escape }}"
                    {% if settings.animations_reveal_on_scroll %}
                      data-cascade
                      style="--animation-order: {{ forloop.index }};"
                    {% endif %}
                  >
                    {% render 'card-product',
                      card_product: product,
                      media_aspect_ratio: section.settings.image_ratio,
                      image_shape: section.settings.image_shape,
                      show_secondary_image: section.settings.show_secondary_image,
                      show_vendor: section.settings.show_vendor,
                      show_rating: section.settings.show_rating,
                      lazy_load: lazy_load,
                      show_quick_add: section.settings.enable_quick_add,
                      section_id: section.id
                    %}
                  </li>
                {%- endfor -%}
              </ul>

              {%- if use_filtered_infinite_scroll -%}
                <div
                  class="collection-infinite-scroll-status"
                  id="CollectionInfiniteScrollStatus"
                  aria-live="polite"
                  aria-busy="false"
                >
                  {% render 'loading-spinner', class: 'loading__spinner hidden' %}
                </div>
                <div id="CollectionInfiniteScrollSentinel" hidden aria-hidden="true"></div>
              {%- elsif paginate.pages > 1 -%}
                {% render 'pagination', paginate: paginate, anchor: '' %}
              {%- endif -%}
            {%- endif -%}

            {%- if use_custom_featured_grid or use_filtered_infinite_scroll -%}
              <script src="{{ 'custom-infinite-scroll.js' | asset_url }}" defer="defer"></script>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endpaginate -%}
  {% if section.settings.image_shape == 'arch' %}
    {% render 'mask-arch' %}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:sections.main-collection-product-grid.name",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Featured products & infinite scroll"
    },
    {
      "type": "checkbox",
      "id": "enable_featured_priority",
      "default": true,
      "label": "Pin featured-tagged products on collection (default sort, no filters)",
      "info": "Shows tagged products first with infinite scroll. Disabled when sorting or filtering is active. Match card options in Theme settings → Templates → product.ajax-card."
    },
    {
      "type": "text",
      "id": "featured_product_tag",
      "label": "Featured product tag",
      "default": "featured",
      "info": "Case-sensitive match to Shopify product tags."
    },
    {
      "type": "checkbox",
      "id": "enable_infinite_scroll_filtered_sorted",
      "default": true,
      "label": "Infinite scroll when filters or sorting are active",
      "info": "Loads more products with the same filters/sort via the storefront (Section Rendering). Uses “Infinite scroll batch size” as the page size for each request."
    },
    {
      "type": "range",
      "id": "infinite_scroll_batch",
      "min": 10,
      "max": 40,
      "step": 10,
      "default": 20,
      "label": "Infinite scroll batch size",
      "info": "Featured mode: non-featured products loaded per scroll. Filtered/sorted mode: products per page for each scroll request."
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 16,
      "label": "t:sections.main-collection-product-grid.settings.products_per_page.label",
      "info": "Used when featured/infinite-scroll mode is off (filters, sort, or setting disabled). Custom mode loads up to 50 products server-side for splitting."
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "t:sections.main-collection-product-grid.settings.columns_desktop.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.header__3.content"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.main-collection-product-grid.settings.image_ratio.options__3.label"
        }
      ],
      "default": "adapt",
      "label": "t:sections.main-collection-product-grid.settings.image_ratio.label"
    },
    {
      "type": "select",
      "id": "image_shape",
      "options": [
        {
          "value": "default",
          "label": "t:sections.all.image_shape.options__1.label"
        },
        {
          "value": "arch",
          "label": "t:sections.all.image_shape.options__2.label"
        },
        {
          "value": "blob",
          "label": "t:sections.all.image_shape.options__3.label"
        },
        {
          "value": "chevronleft",
          "label": "t:sections.all.image_shape.options__4.label"
        },
        {
          "value": "chevronright",
          "label": "t:sections.all.image_shape.options__5.label"
        },
        {
          "value": "diamond",
          "label": "t:sections.all.image_shape.options__6.label"
        },
        {
          "value": "parallelogram",
          "label": "t:sections.all.image_shape.options__7.label"
        },
        {
          "value": "round",
          "label": "t:sections.all.image_shape.options__8.label"
        }
      ],
      "default": "default",
      "label": "t:sections.all.image_shape.label",
      "info": "t:sections.all.image_shape.info"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "t:sections.main-collection-product-grid.settings.show_secondary_image.label"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "t:sections.main-collection-product-grid.settings.show_vendor.label"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "t:sections.main-collection-product-grid.settings.show_rating.label",
      "info": "t:sections.main-collection-product-grid.settings.show_rating.info"
    },
    {
      "type": "checkbox",
      "id": "enable_quick_add",
      "default": false,
      "label": "t:sections.main-collection-product-grid.settings.enable_quick_buy.label"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.header__1.content"
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "default": true,
      "label": "t:sections.main-collection-product-grid.settings.enable_filtering.label",
      "info": "t:sections.main-collection-product-grid.settings.enable_filtering.info"
    },
    {
      "type": "select",
      "id": "filter_type",
      "options": [
        {
          "value": "horizontal",
          "label": "t:sections.main-collection-product-grid.settings.filter_type.options__1.label"
        },
        {
          "value": "vertical",
          "label": "t:sections.main-collection-product-grid.settings.filter_type.options__2.label"
        },
        {
          "value": "drawer",
          "label": "t:sections.main-collection-product-grid.settings.filter_type.options__3.label"
        }
      ],
      "default": "horizontal",
      "label": "t:sections.main-collection-product-grid.settings.filter_type.label",
      "info": "t:sections.main-collection-product-grid.settings.filter_type.info"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "default": true,
      "label": "t:sections.main-collection-product-grid.settings.enable_sorting.label"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.header_mobile.content"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "t:sections.main-collection-product-grid.settings.columns_mobile.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__2.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
